/* Lorne IDE — Dark Purple Theme (default) */

Screen {
    background: #0D0D0D;
    color: #E5E7EB;
}

/* ─── Header / Footer ───────────────────────────── */

Header {
    background: #1a1a2e;
    color: #A78BFA;
    dock: top;
    height: 1;
}

#top-bar {
    dock: top;
    height: 1;
    background: #1a1a2e;
    layout: horizontal;
    padding: 0 0 0 1;
    align-horizontal: left;
}

#app-chat-btn {
    height: 1;
    min-width: 10;
    background: #8B5CF6;
    color: #ffffff;
    text-style: bold;
    border: none;
    margin: 0 0 0 2;
}

#app-chat-btn:hover {
    background: #A78BFA;
}

#app-exit-btn {
    height: 1;
    min-width: 8;
    background: #EF4444;
    color: #ffffff;
    text-style: bold;
    border: none;
    margin: 0;
}

#app-exit-btn:hover {
    background: #DC2626;
}

#top-model-label {
    height: 1;
    color: #A78BFA;
    padding: 0 1;
}

#status-bar {
    background: #1a1a2e;
    color: #6B7280;
    dock: bottom;
    height: 1;
    padding: 0 1;
}

/* ─── Main 3-Column Layout ──────────────────────── */

#main {
    layout: horizontal;
    height: 1fr;
}

#col-left {
    width: 28;
    min-width: 14;
    max-width: 50;
    layout: vertical;
    border-right: solid #2D2D3D;
}

#workspace-center {
    width: 1fr;
    min-width: 36;
    height: 1fr;
    layout: vertical;
}

/* ─── Panel Containers ──────────────────────────── */

#file-explorer {
    height: 2fr;
    border-bottom: solid #2D2D3D;
}

#active-agents {
    height: 1fr;
    min-height: 6;
}

/* ─── TabbedContent Styling ─────────────────────── */

TabbedContent {
    background: #0D0D0D;
}

TabPane {
    background: #0D0D0D;
    padding: 0;
}

Tabs {
    background: #151520;
    height: 3;
}

Tab {
    background: #151520;
    color: #6B7280;
    padding: 0 1;
}

Tab:hover {
    background: #1a1a2e;
    color: #A78BFA;
}

Tab.-active {
    background: #1a1a2e;
    color: #A78BFA;
    text-style: bold;
}

Underline {
    color: #8B5CF6;
}

/* ─── File Explorer ─────────────────────────────── */

#file-tree-header {
    height: 1;
    dock: top;
    layout: horizontal;
    background: #1a1a2e;
    padding: 0;
}

#tree-root-label {
    width: 1fr;
    height: 1;
    color: #A78BFA;
    text-style: bold;
}

#btn-refresh {
    width: 4;
    height: 1;
    min-width: 4;
    background: #2D2D3D;
    color: #A78BFA;
    border: none;
    margin: 0;
}

#btn-refresh:hover {
    background: #8B5CF6;
    color: #ffffff;
}

.header-btn {
    width: 4;
    height: 1;
    min-width: 4;
    background: #2D2D3D;
    border: none;
    margin: 0;
}

#file-explorer FilteredDirectoryTree {
    background: #0D0D0D;
    padding: 0;
    scrollbar-color: #8B5CF6;
    scrollbar-background: #1a1a2e;
    height: 1fr;
}

#settings-panel {
    padding: 0 1;
}

#settings-panel .settings-title {
    color: #A78BFA;
    text-style: bold;
    margin: 1 0 1 0;
}

#settings-panel Button {
    height: 4;
    min-height: 4;
    width: 100%;
    margin: 0 0 1 0;
    text-align: left;
    content-align: left middle;
    border: solid #3D3D4D;
    background: #1a1a2e;
    color: #E5E7EB;
}

#settings-panel Button:hover {
    background: #2a1f45;
    border: solid #8B5CF6;
}

FilteredDirectoryTree > .tree--cursor {
    background: #8B5CF6 30%;
    color: #E5E7EB;
}

FilteredDirectoryTree > .tree--highlight {
    background: #8B5CF6 15%;
}

.file-actions {
    height: 3;
    dock: bottom;
    layout: horizontal;
    background: #151520;
    padding: 0;
}

.file-actions Button {
    height: 3;
    min-width: 7;
    background: #2D2D3D;
    color: #E5E7EB;
    margin: 0;
    border: none;
    text-style: bold;
}

.file-actions Button:hover {
    background: #8B5CF6;
    color: #ffffff;
}

.file-actions #btn-del {
    background: #3D2D2D;
    color: #EF4444;
}

.file-actions #btn-del:hover {
    background: #EF4444;
    color: #ffffff;
}

.file-actions #btn-run {
    background: #2D3D2D;
    color: #10B981;
}

.file-actions #btn-run:hover {
    background: #10B981;
    color: #ffffff;
}

.file-actions #btn-ctx {
    background: #2D2D3D;
    color: #3B82F6;
}

.file-actions #btn-ctx:hover {
    background: #3B82F6;
    color: #ffffff;
}

#git-staging {
    padding: 0 1;
}

#git-staging ListView {
    height: 1fr;
    background: #0D0D0D;
}

#commit-input {
    margin: 0 0;
    background: #151520;
    color: #E5E7EB;
    border: solid #2D2D3D;
}

#commit-btn {
    width: 100%;
    background: #8B5CF6;
    color: #ffffff;
    text-style: bold;
    margin: 0 0;
}

#commit-btn:hover {
    background: #A78BFA;
}

/* ─── Settings Panel ─────────────────────────────── */

#settings-panel {
    padding: 1;
}

#settings-panel Label {
    color: #A78BFA;
    margin: 1 0 0 0;
    text-style: bold;
}

#settings-panel Select {
    width: 100%;
    margin: 0;
}

.palette-container {
    height: 5;
    padding: 0 1;
    margin: 1 0;
    layout: horizontal;
    background: #151520;
    border: solid #2D2D3D;
}

.color-swatch {
    min-width: 6;
    width: 6;
    height: 3;
    border: solid #ffffff 0%;
    margin: 1 1 1 0;
    text-style: bold;
    color: #ffffff00;
}

.color-swatch:hover {
    border: solid #ffffff 100%;
}

/* ─── Code Editor ───────────────────────────────── */

#editor-toolbar {
    dock: top;
    height: 1;
    layout: horizontal;
    background: #151520;
    padding: 0;
}

#editor-toolbar Button {
    height: 1;
    min-width: 8;
    background: #2D2D3D;
    color: #E5E7EB;
    border: none;
    margin: 0;
}

#editor-run-btn { background: #2D3D2D; color: #10B981; }
#editor-run-btn:hover { background: #10B981; color: #ffffff; }
#editor-save-btn:hover { background: #8B5CF6; color: #ffffff; }
#editor-close-btn { background: #3D2D2D; color: #EF4444; }
#editor-close-btn:hover { background: #EF4444; color: #ffffff; }

#code-editor TextArea {
    height: 1fr;
    background: #0D0D0D;
}

/* Notebook cells: не растягивать на всю вкладку — высота задаётся в коде */
#code-editor TextArea.nb-cell-editor {
    height: auto;
    min-height: 1;
    max-height: 150;
    background: #0D0D0D;
}

#editor-tabs {
    background: #0D0D0D;
}

.editor-empty {
    content-align: center middle;
    color: #4B5563;
    text-style: italic;
    height: 1fr;
}

.nb-toolbar {
    height: 3;
    dock: top;
    layout: horizontal;
    background: #151520;
    padding: 0 0 0 0;
    content-align: left middle;
}

.nb-toolbar Button {
    min-width: 12;
    height: 3;
    margin: 0 1 0 0;
    background: #2D2D3D;
    color: #E5E7EB;
    border: none;
    text-style: none;
    content-align: center middle;
}

.nb-toolbar Button:hover {
    background: #3D3D52;
    color: #FFFFFF;
}

/* ─── Notebook Cells ───────────────────────────── */

.nb-cell-header {
    height: 1;
    background: #1a1a2e;
    padding: 0 1;
    margin: 1 0 0 0;
}

.nb-cell-actions {
    height: 3;
    layout: horizontal;
    margin: 0;
    padding: 0;
}

.nb-cell-actions Button {
    margin: 0 1 0 0;
}

.nb-run-btn {
    height: 3;
    min-width: 12;
    background: #2D3D2D;
    color: #10B981;
    border: none;
}

.nb-run-btn:hover { background: #10B981; color: #ffffff; }

.nb-del-btn {
    height: 3;
    min-width: 8;
    background: #3D2D2D;
    color: #FCA5A5;
    border: none;
}

.nb-del-btn:hover {
    background: #EF4444;
    color: #ffffff;
}

.nb-output {
    height: auto;
    min-height: 3;
    max-height: 15;
    background: #151520;
    padding: 0 1;
    border: solid #2D2D3D;
    scrollbar-color: #8B5CF6;
    scrollbar-background: #1a1a2e;
}

.nb-markdown {
    padding: 0 1;
    color: #E5E7EB;
}

.nb-raw {
    padding: 0 1;
    color: #6B7280;
}

/* ─── Find/Replace Overlay ──────────────────────── */

#find-overlay {
    dock: top;
    height: auto;
    max-height: 6;
    background: #1a1a2e;
    padding: 0 1;
    border-bottom: solid #8B5CF6;
    display: none;
}

#find-overlay.visible {
    display: block;
}

#find-overlay Input {
    width: 1fr;
    background: #151520;
    color: #E5E7EB;
    border: solid #2D2D3D;
    margin: 0 1 0 0;
}

#find-overlay Button {
    min-width: 6;
    height: 3;
    background: #2D2D3D;
    color: #E5E7EB;
    margin: 0;
}

#find-overlay Button:hover {
    background: #8B5CF6;
}

#find-row, #replace-row {
    height: 3;
    layout: horizontal;
}

/* ─── Autocomplete Overlay ──────────────────────── */

#autocomplete-overlay {
    display: none;
    layer: overlay;
    background: #1a1a2e;
    border: solid #8B5CF6;
    max-height: 10;
    width: 40;
    padding: 0;
}

#autocomplete-overlay.visible {
    display: block;
}

#autocomplete-overlay ListView {
    background: #1a1a2e;
    height: auto;
    max-height: 10;
}

#autocomplete-overlay ListItem {
    padding: 0 1;
    color: #E5E7EB;
}

#autocomplete-overlay ListItem:hover {
    background: #8B5CF6 30%;
}

/* ─── Terminal Panel ────────────────────────────── */

#term-tab-bar {
    height: 3;
    dock: top;
    background: #151520;
    layout: horizontal;
    padding: 0 1;
}

#term-new-tab {
    height: 3;
    min-width: 14;
    background: #8B5CF6;
    color: #ffffff;
    text-style: bold;
    margin: 0 1 0 0;
    border: none;
}

#term-new-tab:hover {
    background: #A78BFA;
}

#term-tab-bar Button {
    height: 3;
    min-width: 3;
    background: #2D2D3D;
    color: #A78BFA;
    margin: 0 1 0 0;
}

.term-close-btn {
    height: 3;
    min-width: 6;
    background: #3D2D2D;
    color: #EF4444;
}

.term-close-btn:hover {
    background: #EF4444;
    color: #ffffff;
}

#terminal-panel Terminal {
    height: 1fr;
    min-height: 6;
    background: #0D0D0D;
}

.term-run-output {
    height: auto;
    min-height: 5;
    max-height: 14;
    background: #0D0D0D;
    border-top: solid #2D2D3D;
    padding: 0 1;
}

.term-fallback {
    height: 1fr;
    background: #0D0D0D;
    padding: 0 1;
}

.term-fallback RichLog {
    height: 1fr;
    background: #0D0D0D;
}

.term-fallback Input {
    dock: bottom;
    background: #151520;
    color: #E5E7EB;
    border: solid #2D2D3D;
}

/* ─── Version Control ───────────────────────────── */

#version-control .branch-bar {
    height: 3;
    layout: horizontal;
    background: #151520;
    padding: 0 1;
}

.branch-item {
    width: 100%;
    height: 1;
    min-width: 10;
    background: #0D0D0D;
    color: #E5E7EB;
    text-align: left;
    border: none;
    margin: 0;
}

.branch-item:hover {
    background: #8B5CF6 30%;
}

#branch-actions {
    height: 3;
    dock: bottom;
    layout: horizontal;
    background: #151520;
}

#version-control Button {
    min-width: 8;
    height: 3;
    background: #2D2D3D;
    color: #E5E7EB;
    margin: 0 1 0 0;
}

#version-control Button:hover {
    background: #8B5CF6;
}

#version-control Tree {
    background: #0D0D0D;
    height: 1fr;
    scrollbar-color: #8B5CF6;
    scrollbar-background: #1a1a2e;
}

#version-control Tree > .tree--cursor {
    background: #8B5CF6 30%;
}

.staging-header {
    height: 1;
    background: #1a1a2e;
    color: #A78BFA;
    text-style: bold;
    padding: 0 1;
    margin: 1 0 0 0;
}

.stage-checkbox {
    height: 1;
    padding: 0 1;
    color: #E5E7EB;
}

#hotkeys-display {
    padding: 0 1;
    color: #6B7280;
}

/* ─── AI Chat ───────────────────────────────────── */

#main-chat-stream, #chat-messages-worker {
    height: 1fr;
    background: #0D0D0D;
    padding: 0 1;
    scrollbar-color: #8B5CF6;
    scrollbar-background: #1a1a2e;
}

#chat-input-area {
    dock: bottom;
    height: auto;
    max-height: 40;
    background: #0D0D0D;
    padding: 1;
}

#chat-input {
    min-height: 3;
    max-height: 12;
    height: auto;
    background: #0D0D0D;
    color: #E5E7EB;
    border: solid #2D2D3D;
    margin: 0 0 1 0;
}

#ctx-meter-row {
    height: auto;
    min-height: 2;
    layout: horizontal;
    align: left middle;
    margin: 0 0 1 0;
}

#ctx-progress-visual {
    width: 1fr;
    min-width: 18;
    height: auto;
    min-height: 1;
    color: #9CA3AF;
}

#ctx-session-line {
    width: auto;
    min-width: 8;
    height: auto;
    color: #6B7280;
    text-align: right;
    content-align: right middle;
}

.attach-chip {
    height: auto;
    min-height: 3;
    text-align: left;
    content-align: left middle;
}

#chat-controls {
    layout: horizontal;
    height: auto;
    min-height: 3;
    align: left middle;
}

#chat-controls Select {
    height: auto;
    min-height: 3;
    color: #E5E7EB;
    background: #0D0D0D;
}

#model-select {
    width: 2fr;
    min-width: 26;
    max-width: 100%;
    height: 3;
}

#model-select SelectCurrent {
    background: #0D0D0D;
    color: #A78BFA;
    border: solid #2D2D3D;
    height: 3;
}

#model-select SelectOverlay {
    background: #1a1a2e;
    color: #E5E7EB;
    border: solid #8B5CF6;
}

#model-select SelectOverlay OptionList {
    background: #1a1a2e;
}

#mode-select {
    width: 1fr;
    min-width: 16;
    max-width: 100%;
    height: 3;
    margin: 0 1;
}

#mode-select SelectCurrent {
    background: #0D0D0D;
    color: #A78BFA;
    border: solid #2D2D3D;
    height: 3;
}

#stop-btn {
    min-width: 8;
    height: 3;
    background: #2D2D3D;
    color: #6B7280;
    margin: 0 1;
    display: none;
}

#stop-btn.visible {
    display: block;
    background: #EF4444;
    color: #ffffff;
    text-style: bold;
}

#stop-btn.visible:hover {
    background: #DC2626;
}

#attach-file-btn {
    min-width: 18;
    height: 3;
    background: #2D2D3D;
    color: #E5E7EB;
}

#attach-file-btn:hover {
    background: #3D3D4D;
}

#send-btn {
    min-width: 12;
    height: 3;
    background: #8B5CF6;
    color: #ffffff;
    text-style: bold;
}

#send-btn:hover {
    background: #A78BFA;
}

/* ─── AI Settings Panel ─────────────────────────── */

#ai-settings {
    padding: 1;
}

#ai-settings Input {
    width: 100%;
    background: #151520;
    color: #E5E7EB;
    border: solid #2D2D3D;
    margin: 0 0 1 0;
}

#ai-settings Button {
    width: 100%;
    background: #8B5CF6;
    color: #ffffff;
    margin: 0 0 1 0;
}

#ai-settings Label {
    color: #A78BFA;
    margin: 1 0 0 0;
    text-style: bold;
}

/* ─── Active agents tree ─────────────────────────── */

#agents-tree {
    height: 1fr;
    background: #0D0D0D;
    scrollbar-color: #8B5CF6;
    scrollbar-background: #1a1a2e;
}

#agents-tree > .tree--cursor {
    background: #8B5CF6 30%;
}

/* ─── Scrollbars ────────────────────────────────── */

RichLog {
    scrollbar-color: #8B5CF6;
    scrollbar-background: #1a1a2e;
}

Tree {
    scrollbar-color: #8B5CF6;
    scrollbar-background: #1a1a2e;
}

TextArea {
    scrollbar-color: #8B5CF6;
    scrollbar-background: #1a1a2e;
}

/* ─── Density / UI size (compact → spacious) ───── */

.density-compact TabPane { padding: 0; }
.density-compact #chat-input-area { padding: 0; max-height: 32; }
.density-compact #chat-input { min-height: 2; max-height: 8; margin: 0 0 0 0; }
.density-compact #ctx-meter-row {
    layout: vertical;
    min-height: 2;
    height: auto;
    margin: 0 0 0 0;
}
.density-compact #ctx-progress-visual {
    width: 100%;
    min-width: 18;
}
.density-compact #ctx-session-line {
    width: 100%;
    min-width: 18;
    text-align: left;
    content-align: left middle;
}
.density-compact .file-actions { height: 1; min-height: 1; }
.density-compact .file-actions Button { height: 1; min-height: 1; min-width: 5; }
.density-compact Tabs { height: 1; min-height: 1; }
.density-compact Tab { padding: 0; min-height: 1; }
.density-compact #chat-controls { min-height: 1; }
.density-compact #chat-controls Button { height: 1; min-height: 1; min-width: 8; }
.density-compact #chat-controls Select { min-height: 1; height: auto; }
.density-compact #model-select { height: 1; min-height: 1; }
.density-compact #model-select SelectCurrent { height: 1; min-height: 1; }
.density-compact #mode-select { height: 1; min-height: 1; margin: 0 1; }
.density-compact #mode-select SelectCurrent { height: 1; min-height: 1; }
.density-compact #send-btn { min-width: 10; height: 1; min-height: 1; }
.density-compact #attach-file-btn { min-width: 12; height: 1; min-height: 1; }
.density-compact #stop-btn { height: 1; min-height: 1; min-width: 6; }
.density-compact .attach-chip { min-height: 2; min-width: 8; }
.density-compact #main-chat-stream, .density-compact #chat-messages-worker { padding: 0; }
.density-compact #agents-panel-title { height: 1; min-height: 1; padding: 0; }
.density-compact #tree-root-label { height: 1; }

.density-normal #chat-input { min-height: 3; max-height: 12; }

.density-spacious TabPane { padding: 1; }
.density-spacious #chat-input-area { padding: 1 2; max-height: 48; }
.density-spacious #chat-input { min-height: 5; max-height: 18; margin: 0 0 1 0; }
.density-spacious #ctx-meter-row { min-height: 3; margin: 0 0 1 0; }
.density-spacious .file-actions { height: 5; min-height: 5; }
.density-spacious .file-actions Button { height: 5; min-height: 5; min-width: 10; }
.density-spacious Tabs { height: 5; min-height: 5; }
.density-spacious Tab { padding: 0 2; min-height: 5; }
.density-spacious #chat-controls { min-height: 5; }
.density-spacious #chat-controls Button { height: 5; min-height: 5; min-width: 14; }
.density-spacious #chat-controls Select { min-height: 5; height: auto; }
.density-spacious #model-select { height: 5; min-height: 5; }
.density-spacious #model-select SelectCurrent { height: 5; min-height: 5; }
.density-spacious #mode-select { height: 5; min-height: 5; margin: 0 1; }
.density-spacious #mode-select SelectCurrent { height: 5; min-height: 5; }
.density-spacious #send-btn { min-width: 14; height: 5; min-height: 5; }
.density-spacious #attach-file-btn { min-width: 20; height: 5; min-height: 5; }
.density-spacious #stop-btn { height: 5; min-height: 5; min-width: 10; }
.density-spacious .attach-chip { min-height: 5; min-width: 14; }
.density-spacious #main-chat-stream, .density-spacious #chat-messages-worker { padding: 0 2; }
.density-spacious #agents-panel-title { padding: 0 1; min-height: 3; }
.density-spacious #tree-root-label { padding: 0 1; }

/* ═══════════════════════════════════════════════════
   THEME: MONOKAI
   ═══════════════════════════════════════════════════ */

.theme-monokai Screen { background: #272822; }
.theme-monokai Header { background: #3E3D32; color: #F8F8F2; }
.theme-monokai #status-bar { background: #3E3D32; color: #75715E; }

.theme-monokai TabbedContent { background: #272822; }
.theme-monokai TabPane { background: #272822; }
.theme-monokai Tabs { background: #3E3D32; }
.theme-monokai Tab { background: #3E3D32; color: #75715E; }
.theme-monokai Tab:hover { background: #49483E; color: #F8F8F2; }
.theme-monokai Tab.-active { background: #49483E; color: #A6E22E; text-style: bold; }
.theme-monokai Underline { color: #A6E22E; }

.theme-monokai #col-left { border-right: solid #49483E; }
.theme-monokai #file-explorer { border-bottom: solid #49483E; }
